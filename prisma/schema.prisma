// Lottus Sharm Tourism — Prisma Schema
// MySQL on Hostinger

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============
enum Locale {
  AR
  EN
  RU
  IT
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
}

enum TripCategory {
  SEA
  DESERT
  CITY
  DIVING
  EVENTS
  SAFARI
}

enum ScheduleType {
  DAILY
  WEEKLY
  CUSTOM
}

enum BulletType {
  INCLUDE
  EXCLUDE
  BRING
}

enum MediaType {
  IMAGE
  VIDEO
}

enum CustomerType {
  LOCAL
  FOREIGN
}

enum Currency {
  EGP
  USD
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  VODAFONE_CASH
  INSTAPAY
  BANK_TRANSFER
  CASH
}

enum DiscountType {
  PERCENT
  FIXED
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

// ============== AUTH ==============
model AdminUser {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(EDITOR)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastLoginAt  DateTime?

  uploadedMedia    Media[]
  confirmedPayments Payment[] @relation("PaymentConfirmer")
  authoredPosts    BlogPost[]
}

// ============== MEDIA ==============
model Media {
  id           Int       @id @default(autoincrement())
  type         MediaType @default(IMAGE)
  filename     String
  url          String    @db.VarChar(500)
  thumbnailUrl String?   @db.VarChar(500)
  mediumUrl    String?   @db.VarChar(500)
  width        Int?
  height       Int?
  sizeBytes    Int       @default(0)
  altAr        String?
  altEn        String?
  uploadedById Int?
  createdAt    DateTime  @default(now())

  uploadedBy AdminUser? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  tripsAsHero  Trip[]      @relation("TripHero")
  tripsAsCover BlogPost[]  @relation("PostCover")
  tripGallery  TripMedia[]

  @@index([type])
}

// ============== TRIPS ==============
model Trip {
  id              Int          @id @default(autoincrement())
  slug            String       @unique
  category        TripCategory @default(SEA)
  durationMinutes Int          @default(240)
  startTime       String?      @db.VarChar(10)
  scheduleType    ScheduleType @default(DAILY)
  scheduleDays    Json?
  meetingPoint    String?      @db.VarChar(300)
  capacity        Int          @default(0)
  priceLocalEGP   Decimal      @db.Decimal(10, 2)
  priceForeignUSD Decimal      @db.Decimal(10, 2)
  childDiscount   Int          @default(0)
  isFeatured      Boolean      @default(false)
  isActive        Boolean      @default(true)
  sortOrder       Int          @default(0)
  heroImageId     Int?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  heroImage    Media?            @relation("TripHero", fields: [heroImageId], references: [id], onDelete: SetNull)
  translations TripTranslation[]
  gallery      TripMedia[]
  highlights   TripHighlight[]
  bullets      TripBulletPoint[]
  bookings     Booking[]
  reviews      Review[]

  @@index([category])
  @@index([isFeatured])
  @@index([isActive])
}

model TripTranslation {
  id        Int     @id @default(autoincrement())
  tripId    Int
  locale    Locale
  title     String  @db.VarChar(255)
  shortDesc String  @db.Text
  longDesc  String  @db.LongText
  metaTitle String? @db.VarChar(255)
  metaDesc  String? @db.Text

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, locale])
}

model TripHighlight {
  id     Int @id @default(autoincrement())
  tripId Int
  order  Int @default(0)

  trip         Trip                       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  translations TripHighlightTranslation[]
}

model TripHighlightTranslation {
  id          Int    @id @default(autoincrement())
  highlightId Int
  locale      Locale
  text        String @db.VarChar(500)

  highlight TripHighlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)

  @@unique([highlightId, locale])
}

model TripBulletPoint {
  id     Int        @id @default(autoincrement())
  tripId Int
  type   BulletType
  order  Int        @default(0)

  trip         Trip                         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  translations TripBulletPointTranslation[]

  @@index([tripId, type])
}

model TripBulletPointTranslation {
  id       Int    @id @default(autoincrement())
  bulletId Int
  locale   Locale
  text     String @db.VarChar(500)

  bullet TripBulletPoint @relation(fields: [bulletId], references: [id], onDelete: Cascade)

  @@unique([bulletId, locale])
}

model TripMedia {
  id      Int @id @default(autoincrement())
  tripId  Int
  mediaId Int
  order   Int @default(0)

  trip  Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([tripId, mediaId])
}

// ============== CUSTOMERS & BOOKINGS ==============
model Customer {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String
  phone     String
  country   String?
  language  Locale   @default(AR)
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  bookings Booking[]

  @@index([email])
  @@index([phone])
}

model Booking {
  id            Int           @id @default(autoincrement())
  reference     String        @unique @db.VarChar(40)
  tripId        Int
  customerId    Int
  bookingDate   DateTime
  adultsCount   Int           @default(1)
  childrenCount Int           @default(0)
  customerType  CustomerType  @default(LOCAL)
  subtotal      Decimal       @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  currency      Currency      @default(EGP)
  couponId      Int?
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  notes         String?       @db.Text
  adminNotes    String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  trip     Trip      @relation(fields: [tripId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  coupon   Coupon?   @relation(fields: [couponId], references: [id])
  payments Payment[]

  @@index([status])
  @@index([bookingDate])
}

model Payment {
  id                    Int           @id @default(autoincrement())
  bookingId             Int
  amount                Decimal       @db.Decimal(10, 2)
  currency              Currency
  method                PaymentMethod
  status                PaymentStatus @default(UNPAID)
  stripeSessionId       String?       @db.VarChar(255)
  stripePaymentIntentId String?       @db.VarChar(255)
  screenshotUrl         String?       @db.VarChar(500)
  confirmedById         Int?
  confirmedAt           DateTime?
  notes                 String?       @db.Text
  createdAt             DateTime      @default(now())

  booking     Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  confirmedBy AdminUser? @relation("PaymentConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)

  @@index([status])
}

// ============== COUPONS ==============
model Coupon {
  id               Int          @id @default(autoincrement())
  code             String       @unique @db.VarChar(50)
  discountType     DiscountType
  discountValue    Decimal      @db.Decimal(10, 2)
  validFrom        DateTime
  validUntil       DateTime
  maxUses          Int?
  usedCount        Int          @default(0)
  minBookingAmount Decimal?     @db.Decimal(10, 2)
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())

  bookings Booking[]
}

// ============== BLOG ==============
model BlogPost {
  id           Int        @id @default(autoincrement())
  slug         String     @unique
  authorId     Int
  coverImageId Int?
  status       PostStatus @default(DRAFT)
  publishedAt  DateTime?
  readTime     Int        @default(5)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  author       AdminUser             @relation(fields: [authorId], references: [id])
  coverImage   Media?                @relation("PostCover", fields: [coverImageId], references: [id], onDelete: SetNull)
  translations BlogPostTranslation[]
  tags         BlogPostTag[]

  @@index([status])
}

model BlogPostTranslation {
  id        Int     @id @default(autoincrement())
  postId    Int
  locale    Locale
  title     String  @db.VarChar(255)
  excerpt   String  @db.Text
  content   String  @db.LongText
  metaTitle String? @db.VarChar(255)
  metaDesc  String? @db.Text

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
}

model BlogTag {
  id           Int                  @id @default(autoincrement())
  slug         String               @unique
  translations BlogTagTranslation[]
  posts        BlogPostTag[]
}

model BlogTagTranslation {
  id     Int    @id @default(autoincrement())
  tagId  Int
  locale Locale
  name   String @db.VarChar(100)

  tag BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
}

model BlogPostTag {
  postId Int
  tagId  Int

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

// ============== STATIC PAGES CMS ==============
model StaticPage {
  id           Int                     @id @default(autoincrement())
  slug         String                  @unique
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  translations StaticPageTranslation[]
}

model StaticPageTranslation {
  id        Int     @id @default(autoincrement())
  pageId    Int
  locale    Locale
  title     String  @db.VarChar(255)
  content   String  @db.LongText
  metaTitle String? @db.VarChar(255)
  metaDesc  String? @db.Text

  page StaticPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
}

// ============== REVIEWS ==============
model Review {
  id           Int      @id @default(autoincrement())
  tripId       Int
  customerName String
  rating       Int
  comment      String   @db.Text
  locale       Locale   @default(AR)
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([isApproved])
}

// ============== SETTINGS ==============
model SiteSettings {
  id              Int    @id @default(1)
  companyNameAr   String @default("لوتتس شرم للسياحة")
  companyNameEn   String @default("Lottus Sharm Tourism")
  companyNameRu   String @default("Лотус Шарм Туризм")
  companyNameIt   String @default("Lottus Sharm Turismo")
  taglineAr       String @default("اكتشف جمال شرم الشيخ مع لوتتس شرم")
  taglineEn       String @default("Discover the Beauty of Sharm El Sheikh with Lottus Sharm")
  taglineRu       String @default("Откройте для себя красоту Шарм-эль-Шейха с Lottus Sharm")
  taglineIt       String @default("Scopri la bellezza di Sharm El Sheikh con Lottus Sharm")
  phone           String @default("01090767278")
  whatsapp        String @default("201090767278")
  email           String? @default("info@lottussharm.com")
  addressAr       String? @db.Text
  addressEn       String? @db.Text
  facebookUrl     String? @db.VarChar(500)
  instagramUrl    String? @db.VarChar(500)
  tiktokUrl       String? @db.VarChar(500)
  youtubeUrl      String? @db.VarChar(500)
  bankName        String? @default("بنك أبو ظبي الإسلامي")
  bankAccount     String? @default("100001177381")
  vodafoneCash    String? @default("01090767278")
  instaPay        String? @default("lottussharm")
  logoUrl         String? @db.VarChar(500)
  faviconUrl      String? @db.VarChar(500)
  primaryColor    String @default("#0891b2")
  accentColor     String @default("#f59e0b")
  yearsExperience Int    @default(13)
  updatedAt       DateTime @updatedAt
}

// ============== NEWSLETTER ==============
model NewsletterSubscriber {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  locale       Locale   @default(AR)
  subscribedAt DateTime @default(now())
  isActive     Boolean  @default(true)
}

// ============== CONTACT INQUIRIES ==============
model ContactInquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  locale    Locale   @default(AR)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
}
